# Example .env for the llama-cpp.docker image.
#
# This file IS committed as an example. Keep public HuggingFace URLs and example
# tuning values here. For personal overrides (e.g. a real HF_TOKEN), edit locally
# and review `git diff` before pushing so you never accidentally commit a secret.
#
# See README.md for the full variable reference and additional model examples.
# See AGENTS.md for design notes.

# HuggingFace token. Leave empty for public repos; required only for gated repos.
HF_TOKEN=

# Gemma 4 E2B-it (Unsloth) — small multimodal model with separate MTP drafter.
# Total download ~4.2 GB; runs on ~6 GB VRAM. Exercises MODEL_URL + MMPROJ_URL
# + MTP_URL together against this image's entrypoint.
MODEL_URL=https://huggingface.co/unsloth/gemma-4-E2B-it-GGUF/resolve/main/gemma-4-E2B-it-Q4_K_M.gguf
MMPROJ_URL=https://huggingface.co/unsloth/gemma-4-E2B-it-GGUF/resolve/main/mmproj-F16.gguf
MTP_URL=https://huggingface.co/unsloth/gemma-4-E2B-it-GGUF/resolve/main/mtp-gemma-4-E2B-it.gguf
SPEC_TYPE=draft-mtp

# Runtime tuning — conservative values for a small model.
CTX_SIZE=32768          # E2B advertises 128K; stay conservative on tight memory
GPU_LAYERS=99           # Offload all layers to GPU
TEMPERATURE=0.7
TOP_P=0.95
TOP_K=64
PARALLEL=1
FLASH_ATTN=1
BATCH_SIZE=2048         # Upstream default; faster prefill than 512

# Infrastructure
PORT=8080